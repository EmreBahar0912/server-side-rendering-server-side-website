{% render 'partials/head.liquid' %}

<h1>Nieuws</h1>
<input type="text" placeholder="Zoek in nieuws...">

<details>
    <summary><span>Sorteer artikelen</span><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down-icon lucide-chevron-down"><path d="m6 9 6 6 6-6"/></svg></summary>
    <ul>
        <li><a href="/algemeen-nieuws-nieuw-oud">Nieuw-oud</a></li>
        <li><a href="/algemeen-nieuws-oud-nieuw">Oud-nieuw</a></li>
    </ul>
</details>

<article class="grid-container">
{% for story in stories %}
    <section class="test-news">
        <img src="https://fdnd-agency.directus.app/assets/{{ story.cover.id }}" alt="">
        <h2>{{ story.title }}</h2>
        <p>{{ story.intro }}</p>
        <time>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar-icon lucide-calendar"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
            <span>{{ story.date }}</span>
        </time>
    </section>
{% endfor %}
</article>

{% render 'partials/foot.liquid' %}